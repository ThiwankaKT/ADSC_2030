IB <- read.csv("Italian_Birds - Copy.csv")
IB <- IB %>%
mutate(DOM.LU = case_when(
DOM.LU == "Urban Areas" ~ "Urban",
DOM.LU == "Grassland" ~ "Grasslands",
DOM.LU == "Agricultural Area" ~ "Agricultural Areas",
TRUE ~ DOM.LU
))
IB$DOM.LU <- as.factor(IB$DOM.LU)
IB$Spatial.unit <- as.factor(IB$Spatial.unit)
IB$Spatial_Scale <- factor(sub(".*(100|250).*", "\\1", IB$Spatial.unit))
colnames(IB)[colnames(IB) == "SUM.AREA"] <- "SUM_AREA"
# Splitting the dataset
IB_100 <- IB %>% filter(Spatial_Scale == "100")
IB_250 <- IB %>% filter(Spatial_Scale == "250")
# Poisson models
poi_model_100 <- glm(BSR ~ Spatial.unit + DOM.LU + Spatial.unit:DOM.LU, family = poisson(link = "log"), data = IB_100, offset = log(SUM_AREA))
poi_model_250 <- glm(BSR ~ Spatial.unit + DOM.LU + Spatial.unit:DOM.LU, family = poisson(link = "log"), data = IB_250, offset = log(SUM_AREA))
summary(poi_model_100)
summary(poi_model_250)
# Overdispersion tests
dispersiontest(poi_model_100,trafo=1) #trafo = transformation function - linear specification
library(MASS)
library(dplyr)
library(AER)
IB <- read.csv("Italian_Birds - Copy.csv")
IB <- IB %>%
mutate(DOM.LU = case_when(
DOM.LU == "Urban Areas" ~ "Urban",
DOM.LU == "Grassland" ~ "Grasslands",
DOM.LU == "Agricultural Area" ~ "Agricultural Areas",
TRUE ~ DOM.LU
))
IB$DOM.LU <- as.factor(IB$DOM.LU)
IB$Spatial.unit <- as.factor(IB$Spatial.unit)
IB$Spatial_Scale <- factor(sub(".*(100|250).*", "\\1", IB$Spatial.unit))
colnames(IB)[colnames(IB) == "SUM.AREA"] <- "SUM_AREA"
# Splitting the dataset
IB_100 <- IB %>% filter(Spatial_Scale == "100")
IB_250 <- IB %>% filter(Spatial_Scale == "250")
# Poisson models
poi_model_100 <- glm(BSR ~ Spatial.unit + DOM.LU + Spatial.unit:DOM.LU, family = poisson(link = "log"), data = IB_100, offset = log(SUM_AREA))
poi_model_250 <- glm(BSR ~ Spatial.unit + DOM.LU + Spatial.unit:DOM.LU, family = poisson(link = "log"), data = IB_250, offset = log(SUM_AREA))
summary(poi_model_100)
summary(poi_model_250)
# Overdispersion tests
dispersiontest(poi_model_100,trafo=1) #trafo = transformation function - linear specification
dispersiontest(poi_model_250,trafo=1) #trafo = transformation function - linear specification
## Overdispersion detected
# Negative Binomial models
nb_model_100 <- glm.nb(BSR ~ Spatial.unit + DOM.LU + Spatial.unit:DOM.LU + offset(log(SUM_AREA)), data = IB_100, link = "log")
nb_model_250 <- glm.nb(BSR ~ Spatial.unit + DOM.LU + Spatial.unit:DOM.LU + offset(log(SUM_AREA)), data = IB_250, link = "log")
summary(nb_model_100)
summary(nb_model_250)
summary(nb_model_100)
summary(nb_model_250)
library(lmtest)
lrtest(nb_model_100, nb_model_250)
lrtest(poi_model_100, nb_model_100)
lrtest(poi_model_250, nb_model_250)
AIC(poi_model_100, nb_model_100, poi_model_250, nb_model_250)
AIC(poi_model_100, nb_model_100)
BIC(poi_model_100, nb_model_100)
summary(nb_model_100)
AIC(poi_model_250, nb_model_250)
BIC(poi_model_250, nb_model_250)
summary(nb_model_100)
summary(nb_model_250)
plot(nb_model_100, 1)
vif(nb_model_100)
plot(nb_model_100, 1)
summary(poi_model_100)
summary(poi_model_250)
